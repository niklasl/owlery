prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix : <http://example.org/ns/>
base <https://example.org/>

##
# TBox

[ owl:onProperty _:a_Proposition_of_bought ; owl:hasSelf true ]
  owl:equivalentClass [ owl:onProperty rdf:propositionFormPredicate ;
      owl:hasValue :bought ] .

[ owl:onProperty _:a_Proposition_of_shoppedAt ; owl:hasSelf true ]
  owl:equivalentClass [ owl:onProperty rdf:propositionFormPredicate ;
      owl:hasValue :shoppedAt ] .

[ owl:onProperty _:a_Purchase ; owl:hasSelf true ]
  owl:equivalentClass :Purchase .

_:is_Purchase_of_reified_bought_Proposition owl:propertyChainAxiom (
      _:a_Purchase
      rdf:reifies
      _:a_Proposition_of_bought
    ) .

_:is_Purchase_of_reified_shoppedAt_Proposition owl:propertyChainAxiom (
      _:a_Purchase
      rdf:reifies
      _:a_Proposition_of_shoppedAt
    ) .

:buyer rdfs:domain :Purchase ;
  owl:inverseOf _:buyerOf_Purchase ;
  owl:propertyChainAxiom (
      _:is_Purchase_of_reified_bought_Proposition
      rdf:propositionFormSubject
    ) ;
  owl:propertyChainAxiom (
      _:is_Purchase_of_reified_shoppedAt_Proposition
      rdf:propositionFormSubject
    ) .

:item rdfs:domain :Purchase ;
  owl:propertyChainAxiom (
      _:is_Purchase_of_reified_bought_Proposition
      rdf:propositionFormObject
    ) .

:seller rdfs:domain :Purchase ;
  owl:propertyChainAxiom (
      _:is_Purchase_of_reified_shoppedAt_Proposition
      rdf:propositionFormObject
    ) .

:bought owl:propertyChainAxiom ( _:buyerOf_Purchase :item ) .

:shoppedAt owl:propertyChainAxiom ( _:buyerOf_Purchase :seller ) .

##
# ABox

<Alice> :bought <SomeComputer> ~ <purchase1> .
<Alice> :shoppedAt <ComputerStore> ~ <purchase1> .
<purchase1> a :Purchase ;
  :date "2014-12-15"^^xsd:date ;
  :cost 2500 ;
  :currency :USD .
