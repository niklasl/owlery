prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix : <http://example.org/ns/>
base <https://example.org/>

##
# MetaBox

:selfOfType rdfs:subPropertyOf [ owl:inverseOf owl:onProperty ] ;
  rdfs:range [ owl:onProperty owl:hasSelf ; owl:hasValue true ] .

##
# TBox

:boughtPpn owl:propertyChainAxiom (
      [ :selfOfType :Purchase ]
      rdf:reifies
      [ :selfOfType [ owl:onProperty rdf:triplePredicate ; owl:hasValue :bought ] ]
    ) .

:shoppedAtPpn owl:propertyChainAxiom (
      [ :selfOfType :Purchase ]
      rdf:reifies
      [ :selfOfType [ owl:onProperty rdf:triplePredicate ; owl:hasValue :shoppedAt ] ]
    ) .

:buyer rdfs:domain :Purchase ;
  owl:propertyChainAxiom (:boughtPpn rdf:tripleSubject) ;
  owl:propertyChainAxiom (:shoppedAtPpn rdf:tripleSubject) .

:item rdfs:domain :Purchase ;
  owl:propertyChainAxiom (:boughtPpn rdf:tripleObject) .

:seller rdfs:domain :Purchase ;
  owl:propertyChainAxiom (:shoppedAtPpn rdf:tripleObject) .

:bought owl:propertyChainAxiom ( [ owl:inverseOf :buyer ] :item ) .

:shoppedAt owl:propertyChainAxiom ( [ owl:inverseOf :buyer ] :seller ) .

##
# ABox

<Alice> :bought <SomeComputer> ~ <purchase1> .
<Alice> :shoppedAt <ComputerStore> ~ <purchase1> .
<purchase1> a :Purchase ;
  :date "2014-12-15"^^xsd:date ;
  :cost 2500 ;
  :currency :USD .
  #rdf:reifies <<( <Alice> :bought <SomeComputer> )>> ;
  #rdf:reifies <<( <Alice> :shoppedAt <ComputerStore> )>> .
