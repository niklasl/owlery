prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>
prefix owl: <http://www.w3.org/2002/07/owl#>
prefix : <http://example.org/ns/>
base <https://example.org/>

##
# TBox

:genreForm owl:propertyChainAxiom (:category _:a_GenreForm) .
[ owl:onProperty _:a_GenreForm ; owl:hasSelf true ] owl:equivalentClass :GenreForm .

:contentType owl:propertyChainAxiom (:category _:a_ContentType) .
:ContentType owl:equivalentClass [ owl:onProperty _:a_ContentType ; owl:hasSelf true ] .

:carrierType owl:propertyChainAxiom (:category _:a_CarrierType) .
:CarrierType owl:equivalentClass [ owl:onProperty _:a_CarrierType ; owl:hasSelf true ] .

:LiteraryGenre rdfs:subClassOf :GenreForm .
:PhysicalForm rdfs:subClassOf :GenreForm .

##
# ABox

<novel> a :LiteraryGenre .
<paperback> a :PhysicalForm .
<text> a :ContentType .
<volume> a :CarrierType .

<x> a :Work ;
  :category <novel>, <text> .

<y> a :Instance ;
  :instanceOf <x> ;
  :category <paperback>, <volume> .
