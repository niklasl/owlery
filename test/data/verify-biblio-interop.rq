prefix dct: <http://purl.org/dc/terms/>
prefix foaf: <http://xmlns.com/foaf/0.1/>
prefix bibo: <http://purl.org/ontology/bibo/>
prefix bf: <http://id.loc.gov/ontologies/bibframe/>
prefix bibmap: <http://example.org/ns/bibmap/>
base <http://example.org/>

ask {

  <scholarly_resource>
    bf:contribution <scholarly_resource#ctrb1> .

  <scholarly_resource#ctrb1> a bf:Contribution ;
      bf:agent <some_person> ;
      bf:role <https://credit.niso.org/contributor-roles/data-curation> ;
      bibmap:hasAffiliation <linked_org> .

  filter not exists {

    <some_person> bf:role [] .

    <scholarly_resource#ctrb1> bf:agent <other_person> .

    <other_person> bibmap:hasRole [] ; bibmap:hasAffiliation [] .

  }
}
